# --- App ---
APP_BASE_URL=http://localhost:3000
SESSION_SECRET=change-me-32-byte-hex-or-longer-secret
SESSION_SECRET_PREVIOUS=

# --- Auth Mode: demo | entra | both ---
AUTH_MODE=demo
DEMO_MODE_ENABLED=true

# --- Database ---
# Cloud (Turso) example: libsql://your-db-name.turso.io
# Local SQLite fallback used when DATABASE_URL is empty or starts with "file:"
DATABASE_URL=file:./dev.db
DATABASE_AUTH_TOKEN=
DATABASE_URL_UNPOOLED=

# ----- AI provider -----
# AI_MODE: stub | gateway | azure (default: stub for offline demo)
# - stub:    deterministic, free, no network. Best for hackathon judges.
# - gateway: route through Vercel AI Gateway (requires AI_GATEWAY_API_KEY + model IDs)
# - azure:   direct Azure OpenAI (requires the AZURE_OPENAI_* block below)
AI_MODE=stub

# AI Gateway (only when AI_MODE=gateway)
AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
AI_MODEL_DEFAULT=openai/gpt-4o
AI_MODEL_FAST=openai/gpt-4o-mini
AI_EMBEDDING_MODEL=openai/text-embedding-3-small

# Azure OpenAI (only when AI_MODE=azure)
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
# Use a dated GA version your deployment supports (Azure Portal → deployment → "Target URI").
AZURE_OPENAI_API_VERSION=2024-10-21

# --- Microsoft Entra (optional) ---
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# --- Microsoft Graph (optional) ---
GRAPH_SYNC_ENABLED=false
GRAPH_ADMIN_GROUP_ID=
MAIL_FROM_USER_ID=

# --- Teams Integration (optional) ---
# Incoming webhook URL from Teams channel connector for adaptive card notifications
TEAMS_WEBHOOK_URL_DEFAULT=
# HMAC secret for inbound webhook verification (Teams → AtomicPulse)
TEAMS_WEBHOOK_SECRET=

# --- Email via Graph (optional) ---
# Set to "true" + provide MAIL_FROM_USER_ID to send transactional emails via Graph
GRAPH_MAIL_ENABLED=false

# --- Observability (optional) ---
AZURE_MONITOR_CONN_STRING=
